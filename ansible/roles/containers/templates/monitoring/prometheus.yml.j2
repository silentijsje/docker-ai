---
# Prometheus Configuration
# Deployed by Ansible - Do not edit manually

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']

  - job_name: 'traefik'
    static_configs:
      - targets: ['{{ ansible_host | default(inventory_hostname) }}:{{ container_ports.traefik_metrics }}']

  - job_name: 'crowdsec'
    static_configs:
      - targets: ['{{ ansible_host | default(inventory_hostname) }}:{{ container_ports.crowdsec_metrics }}']
