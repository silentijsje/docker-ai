# Graylog Stack — Auto-generated by Ansible, do not edit manually
# Components: MongoDB (metadata), OpenSearch (log index), Graylog (server)

services:
  {{ graylog_mongo_container_name }}:
    image: {{ graylog_mongo_image }}
    container_name: {{ graylog_mongo_container_name }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.graylog_mongo.memory }}
          cpus: "{{ resource_limits.graylog_mongo.cpus }}"
    volumes:
      - {{ container_data_root }}/graylog/mongo:/data/db
    networks:
      - {{ container_network }}

  {{ graylog_opensearch_container_name }}:
    image: {{ graylog_opensearch_image }}
    container_name: {{ graylog_opensearch_container_name }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.graylog_opensearch.memory }}
          cpus: "{{ resource_limits.graylog_opensearch.cpus }}"
    environment:
      - cluster.name=graylog
      - discovery.type=single-node
      - action.auto_create_index=false
      - DISABLE_SECURITY_PLUGIN=true
      - OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
    volumes:
      - {{ container_data_root }}/graylog/opensearch:/usr/share/opensearch/data
    networks:
      - {{ container_network }}

  {{ graylog_container_name }}:
    image: {{ graylog_image }}
    container_name: {{ graylog_container_name }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.graylog.memory }}
          cpus: "{{ resource_limits.graylog.cpus }}"
    depends_on:
      - {{ graylog_mongo_container_name }}
      - {{ graylog_opensearch_container_name }}
    environment:
      GRAYLOG_NODE_ID_FILE: /usr/share/graylog/data/config/node-id
      GRAYLOG_PASSWORD_SECRET: "{{ vault_graylog_password_secret }}"
      GRAYLOG_ROOT_PASSWORD_SHA2: "{{ vault_graylog_root_password_sha2 }}"
      GRAYLOG_HTTP_BIND_ADDRESS: 0.0.0.0:9000
      GRAYLOG_HTTP_EXTERNAL_URI: "https://graylog.{{ cloudflare_dns_zone }}/"
      GRAYLOG_ELASTICSEARCH_HOSTS: "http://{{ graylog_opensearch_container_name }}:9200"
      GRAYLOG_MONGODB_URI: "mongodb://{{ graylog_mongo_container_name }}:27017/graylog"
      GRAYLOG_TIMEZONE: "{{ container_timezone }}"
      GRAYLOG_MESSAGE_JOURNAL_MAX_SIZE: 512mb
    volumes:
      - {{ container_data_root }}/graylog/data:/usr/share/graylog/data
    ports:
      - "{{ container_ports.graylog_web }}:9000"
      - "{{ container_ports.graylog_syslog }}:5140/tcp"
      - "{{ container_ports.graylog_syslog }}:5140/udp"
    networks:
      - {{ container_network }}
{% if inventory_hostname in groups['proxy'] %}
      - proxy
{% endif %}
    labels:
      - traefik.enable=true
{% if inventory_hostname in groups['proxy'] %}
      - traefik.docker.network=proxy
{% endif %}
      - traefik.http.routers.graylog.service=graylog
      - traefik.http.routers.graylog.rule=Host(`graylog.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.graylog.entrypoints=secureweb
      - traefik.http.routers.graylog.middlewares={{ traefik_router_middlewares }}
      - traefik.http.services.graylog.loadbalancer.server.scheme=http
      - traefik.http.services.graylog.loadbalancer.server.port=9000

networks:
  {{ container_network }}:
    external: true
{% if inventory_hostname in groups['proxy'] %}
  proxy:
    external: true
{% endif %}
