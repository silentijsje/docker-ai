---
###########################################################################
# Jellystat - Jellyfin Statistics
# Deployed by Ansible - Do not edit manually
###########################################################################

services:
  jellystat-db:
    image: {{ jellystat_db_image | default('postgres:15.2') }}
    container_name: {{ jellystat_db_container_name | default('jellystat-db') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.jellystat_db.memory }}
          cpus: "{{ resource_limits.jellystat_db.cpus }}"
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD={{ vault_jellystat_pg_password }}
    volumes:
      - {{ container_data_root }}/jellystat/pgdata:/var/lib/postgresql/data
    networks:
      - {{ container_network }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  jellystat:
    image: {{ jellystat_image | default('cyfershepard/jellystat:latest') }}
    container_name: {{ jellystat_container_name | default('jellystat') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.jellystat.memory }}
          cpus: "{{ resource_limits.jellystat.cpus }}"
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD={{ vault_jellystat_pg_password }}
      - POSTGRES_IP=jellystat-db
      - POSTGRES_PORT=5432
      - JWT_SECRET={{ vault_jellystat_jwt_secret }}
      - PUID={{ container_puid }}
      - PGID={{ container_pgid }}
      - TZ={{ container_timezone }}
    volumes:
      - {{ container_data_root }}/jellystat/backup-data:/app/backend/backup-data
    ports:
      - "{{ container_ports.jellystat }}:3000"
    depends_on:
      jellystat-db:
        condition: service_healthy
    networks:
      - {{ container_network }}
{% if inventory_hostname in groups['proxy'] %}
      - proxy
{% endif %}
    labels:
      - traefik.enable=true
{% if inventory_hostname in groups['proxy'] %}
      - traefik.docker.network=proxy
{% endif %}
      # Router
      - traefik.http.routers.jellystat.service=jellystat
      - traefik.http.routers.jellystat.rule=Host(`jellystat.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.jellystat.entrypoints=secureweb
      - traefik.http.routers.jellystat.middlewares=security-headers@file,traefik-bouncer@file,ipAllowList@file
      # Service
      - traefik.http.services.jellystat.loadbalancer.server.scheme=http
      - traefik.http.services.jellystat.loadbalancer.server.port=3000

networks:
  {{ container_network }}:
    external: true
{% if inventory_hostname in groups['proxy'] %}
  proxy:
    external: true
{% endif %}
