---
###########################################################################
# Paperless-NGX - Document Management System
# Deployed by Ansible - Do not edit manually
# Documentation: https://docs.paperless-ngx.com
###########################################################################

services:
  paperless-redis:
    image: {{ paperless_redis_image | default('redis:8') }}
    container_name: {{ paperless_redis_container_name | default('paperless-redis') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.paperless_redis.memory }}
          cpus: "{{ resource_limits.paperless_redis.cpus }}"
    volumes:
      - {{ container_data_root }}/paperless/redis:/data
    networks:
      - {{ container_network }}

  paperless-db:
    image: {{ paperless_db_image | default('postgres:17') }}
    container_name: {{ paperless_db_container_name | default('paperless-db') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.paperless_db.memory }}
          cpus: "{{ resource_limits.paperless_db.cpus }}"
    environment:
      - POSTGRES_DB=paperless
      - POSTGRES_USER=paperless
      - POSTGRES_PASSWORD={{ vault_paperless_pg_password }}
    volumes:
      - {{ container_data_root }}/paperless/pgdata:/var/lib/postgresql/data
    networks:
      - {{ container_network }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d paperless -U paperless"]
      interval: 10s
      timeout: 5s
      retries: 5

  paperless-webserver:
    image: {{ paperless_image | default('ghcr.io/paperless-ngx/paperless-ngx:latest') }}
    container_name: {{ paperless_container_name | default('paperless-webserver') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.paperless_web.memory }}
          cpus: "{{ resource_limits.paperless_web.cpus }}"
    environment:
      - USERMAP_UID={{ container_puid }}
      - USERMAP_GID={{ container_pgid }}
      - PAPERLESS_REDIS=redis://paperless-redis:6379
      - PAPERLESS_DBHOST=paperless-db
      - PAPERLESS_DBPASS={{ vault_paperless_pg_password }}
      - PAPERLESS_URL=https://paperless.{{ cloudflare_dns_zone }}
      - PAPERLESS_TIKA_ENABLED=1
      - PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://paperless-gotenberg:3000
      - PAPERLESS_TIKA_ENDPOINT=http://paperless-tika:9998
    volumes:
      - {{ container_data_root }}/paperless/data:/usr/src/paperless/data
      - {{ container_data_root }}/paperless/media:/usr/src/paperless/media
      - {{ container_media_root }}/Documents/export:/usr/src/paperless/export
      - {{ container_media_root }}/Documents/consume:/usr/src/paperless/consume
    ports:
      - "{{ container_ports.paperless }}:8000"
    depends_on:
      paperless-db:
        condition: service_healthy
      paperless-redis:
        condition: service_started
      paperless-gotenberg:
        condition: service_started
      paperless-tika:
        condition: service_started
    networks:
      - {{ container_network }}
{% if traefik_enabled | default(false) %}
      - proxy
{% endif %}
    labels:
      - traefik.enable=true
{% if traefik_enabled | default(false) %}
      - traefik.docker.network=proxy
{% endif %}
      # Router
      - traefik.http.routers.paperless.service=paperless
      - traefik.http.routers.paperless.rule=Host(`paperless.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.paperless.entrypoints=secureweb
      - traefik.http.routers.paperless.middlewares=security-headers@file,traefik-bouncer@file,ipAllowList@file
      # Service
      - traefik.http.services.paperless.loadbalancer.server.scheme=http
      - traefik.http.services.paperless.loadbalancer.server.port=8000

  paperless-gotenberg:
    image: {{ paperless_gotenberg_image | default('gotenberg/gotenberg:8.20') }}
    container_name: {{ paperless_gotenberg_container_name | default('paperless-gotenberg') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.paperless_gotenberg.memory }}
          cpus: "{{ resource_limits.paperless_gotenberg.cpus }}"
    command:
      - "gotenberg"
      - "--chromium-disable-javascript=true"
      - "--chromium-allow-list=file:///tmp/.*"
    networks:
      - {{ container_network }}

  paperless-tika:
    image: {{ paperless_tika_image | default('apache/tika:latest') }}
    container_name: {{ paperless_tika_container_name | default('paperless-tika') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.paperless_tika.memory }}
          cpus: "{{ resource_limits.paperless_tika.cpus }}"
    networks:
      - {{ container_network }}

  paperless-ai:
    image: {{ paperless_ai_image | default('clusterzx/paperless-ai:latest') }}
    container_name: {{ paperless_ai_container_name | default('paperless-ai') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.paperless_ai.memory }}
          cpus: "{{ resource_limits.paperless_ai.cpus }}"
    environment:
      - PUID={{ container_puid }}
      - PGID={{ container_pgid }}
      - TZ={{ container_timezone }}
    volumes:
      - {{ container_data_root }}/paperless/ai-data:/app/data
    ports:
      - "{{ container_ports.paperless_ai }}:3000"
    networks:
      - {{ container_network }}

networks:
  {{ container_network }}:
    external: true
{% if traefik_enabled | default(false) %}
  proxy:
    external: true
{% endif %}
