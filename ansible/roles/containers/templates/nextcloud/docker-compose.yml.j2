---
###########################################################################
# Nextcloud - Self-hosted Cloud Storage
# Deployed by Ansible - Do not edit manually
# Documentation: https://docs.linuxserver.io/images/docker-nextcloud
###########################################################################

services:
  nextcloud:
    image: {{ nextcloud_image | default('lscr.io/linuxserver/nextcloud:latest') }}
    container_name: {{ nextcloud_container_name | default('nextcloud') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.nextcloud.memory }}
          cpus: "{{ resource_limits.nextcloud.cpus }}"
    environment:
      - PUID={{ container_puid }}
      - PGID={{ container_pgid }}
      - TZ={{ container_timezone }}
    volumes:
      - {{ container_media_root }}:/media
      - {{ container_data_root }}/nextcloud/config:/config
    ports:
      - "{{ container_ports.nextcloud }}:443"
    depends_on:
      nextcloud-postgresql:
        condition: service_healthy
    networks:
      - {{ container_network }}
{% if inventory_hostname in groups['proxy'] %}
      - proxy
{% endif %}
    labels:
      - traefik.enable=true
{% if inventory_hostname in groups['proxy'] %}
      - traefik.docker.network=proxy
{% endif %}
      # Router
      - traefik.http.routers.nextcloud.service=nextcloud
      - traefik.http.routers.nextcloud.rule=Host(`cloud.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.nextcloud.entrypoints=secureweb
      - traefik.http.routers.nextcloud.middlewares=security-headers@file,traefik-bouncer@file,ipAllowList@file
      # Service
      - traefik.http.services.nextcloud.loadbalancer.server.scheme=https
      - traefik.http.services.nextcloud.loadbalancer.server.port=443

  nextcloud-postgresql:
    image: {{ nextcloud_pg_image | default('postgres:16-alpine') }}
    container_name: {{ nextcloud_pg_container_name | default('nextcloud-postgresql') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.nextcloud_pg.memory }}
          cpus: "{{ resource_limits.nextcloud_pg.cpus }}"
    user: "{{ container_puid }}:{{ container_pgid }}"
    environment:
      - TZ={{ container_timezone }}
      - POSTGRES_DB=nextcloud
      - POSTGRES_USER=nextcloud
      - POSTGRES_PASSWORD={{ vault_nextcloud_pg_password }}
    volumes:
      - {{ container_data_root }}/nextcloud/postgresql:/var/lib/postgresql/data
    networks:
      - {{ container_network }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d nextcloud -U nextcloud"]
      start_period: 20s
      interval: 30s
      retries: 5
      timeout: 5s

networks:
  {{ container_network }}:
    external: true
{% if inventory_hostname in groups['proxy'] %}
  proxy:
    external: true
{% endif %}
