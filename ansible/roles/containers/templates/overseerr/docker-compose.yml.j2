---
###########################################################################
# Overseerr - Media Request Manager
# Deployed by Ansible - Do not edit manually
# Documentation: https://docs.linuxserver.io/images/docker-overseerr
###########################################################################

services:
  overseerr:
    image: {{ overseerr_image | default('lscr.io/linuxserver/overseerr:latest') }}
    container_name: {{ overseerr_container_name | default('overseerr') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.overseerr.memory }}
          cpus: "{{ resource_limits.overseerr.cpus }}"
    environment:
      - PUID={{ container_puid }}
      - PGID={{ container_pgid }}
      - TZ={{ container_timezone }}
    volumes:
      - {{ container_data_root }}/overseerr:/config
    ports:
      - "{{ container_ports.overseerr }}:5055"
    networks:
      - {{ container_network }}
{% if inventory_hostname in groups['proxy'] %}
      - proxy
{% endif %}
    labels:
      - traefik.enable=true
{% if inventory_hostname in groups['proxy'] %}
      - traefik.docker.network=proxy
{% endif %}
      # Router
      - traefik.http.routers.overseerr.service=overseerr
      - traefik.http.routers.overseerr.rule=Host(`overseerr.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.overseerr.entrypoints=secureweb
      - traefik.http.routers.overseerr.middlewares=security-headers@file,traefik-bouncer@file,ipAllowList@file
      # Service
      - traefik.http.services.overseerr.loadbalancer.server.scheme=http
      - traefik.http.services.overseerr.loadbalancer.server.port=5055

networks:
  {{ container_network }}:
    external: true
{% if inventory_hostname in groups['proxy'] %}
  proxy:
    external: true
{% endif %}
