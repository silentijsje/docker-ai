---
###########################################################################
# Seerr - Media Request Manager
# Deployed by Ansible - Do not edit manually
# Documentation: https://github.com/seerr-team/seerr
###########################################################################

services:
  seerr:
    image: {{ seerr_image | default('ghcr.io/seerr-team/seerr:latest') }}
    container_name: {{ seerr_container_name | default('seerr') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.seerr.memory }}
          cpus: "{{ resource_limits.seerr.cpus }}"
    environment:
      - PUID={{ container_puid }}
      - PGID={{ container_pgid }}
      - TZ={{ container_timezone }}
    volumes:
      - {{ container_data_root }}/seerr:/config
    ports:
      - "{{ container_ports.seerr }}:5055"
    networks:
      - {{ container_network }}
{% if inventory_hostname in groups['proxy'] %}
      - proxy
{% endif %}
    labels:
      - traefik.enable=true
{% if inventory_hostname in groups['proxy'] %}
      - traefik.docker.network=proxy
{% endif %}
      # Router
      - traefik.http.routers.seerr.service=seerr
      - traefik.http.routers.seerr.rule=Host(`seerr.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.seerr.entrypoints=secureweb
      - traefik.http.routers.seerr.middlewares=security-headers@file,traefik-bouncer@file,ipAllowList@file
      # Service
      - traefik.http.services.seerr.loadbalancer.server.scheme=http
      - traefik.http.services.seerr.loadbalancer.server.port=5055

networks:
  {{ container_network }}:
    external: true
{% if inventory_hostname in groups['proxy'] %}
  proxy:
    external: true
{% endif %}
