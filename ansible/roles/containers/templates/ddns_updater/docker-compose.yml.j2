---
###########################################################################
# DDNS Updater - Dynamic DNS Updater
# Deployed by Ansible - Do not edit manually
# Documentation: https://github.com/qdm12/ddns-updater
###########################################################################

services:
  ddns-updater:
    image: {{ ddns_updater_image | default('qmcgaw/ddns-updater:latest') }}
    container_name: {{ ddns_updater_container_name | default('ddns-updater') }}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ resource_limits.ddns_updater.memory }}
          cpus: "{{ resource_limits.ddns_updater.cpus }}"
    user: "{{ container_puid }}:{{ container_pgid }}"
    environment:
      - TZ={{ container_timezone }}
      - CONFIG=
      - PERIOD=5m
      - UPDATE_COOLDOWN_PERIOD=5m
      - PUBLICIP_FETCHERS=all
      - PUBLICIP_HTTP_PROVIDERS=all
      - PUBLICIPV4_HTTP_PROVIDERS=all
      - PUBLICIPV6_HTTP_PROVIDERS=all
      - PUBLICIP_DNS_PROVIDERS=all
      - PUBLICIP_DNS_TIMEOUT=3s
      - HTTP_TIMEOUT=10s
      - LISTENING_ADDRESS=:8000
      - ROOT_URL=/
      - BACKUP_PERIOD=0
      - BACKUP_DIRECTORY=/updater/data
      - LOG_LEVEL=info
      - LOG_CALLER=hidden
      - SHOUTRRR_ADDRESSES=
    volumes:
      - {{ container_data_root }}/ddns-updater:/updater/data
    ports:
      - "{{ container_ports.ddns_updater }}:8000"
    networks:
      - {{ container_network }}

networks:
  {{ container_network }}:
    external: true
