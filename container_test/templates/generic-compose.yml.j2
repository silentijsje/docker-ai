---
###########################################################################
# {{ item.name }} — generated by Ansible
# Do not edit manually
###########################################################################

services:
  {{ item.container_name | default(item.name) }}:
    image: {{ item.image }}
    container_name: {{ item.container_name | default(item.name) }}
    restart: unless-stopped
{% if item.hostname is defined %}
    hostname: {{ item.hostname }}
{% endif %}
{% if item.user is defined %}
    user: "{{ item.user }}"
{% endif %}
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: {{ item.memory }}
          cpus: "{{ item.cpus }}"
{% if item.shm_size is defined %}
    shm_size: {{ item.shm_size }}
{% endif %}
{% set has_env = (item.add_puid_pgid | default(true)) or (item.env is defined and item.env | length > 0) %}
{% if has_env or (item.env_file is defined) %}
{% if item.env_file is defined %}
    env_file:
      - {{ item.env_file }}
{% endif %}
    environment:
{% if item.add_puid_pgid | default(true) %}
      - PUID={{ container_puid }}
      - PGID={{ container_pgid }}
      - TZ={{ container_timezone }}
{% endif %}
{% if item.env is defined %}
{% for var in item.env %}
      - {{ var }}
{% endfor %}
{% endif %}
{% endif %}
{% if item.volumes is defined and item.volumes | length > 0 %}
    volumes:
{% for vol in item.volumes %}
      - {{ vol }}
{% endfor %}
{% endif %}
{% if item.host_port is defined %}
    ports:
      - "{{ item.host_port }}:{{ item.internal_port }}"
{% if item.extra_ports is defined %}
{% for port in item.extra_ports %}
      - "{{ port }}"
{% endfor %}
{% endif %}
{% endif %}
    networks:
      - {{ container_network }}
{% if item.traefik is defined and (item.proxy_network | default(true)) and (traefik_enabled | default(false)) %}
      - proxy
{% endif %}
{% if item.traefik is defined %}
    labels:
      - traefik.enable=true
{% if traefik_enabled | default(false) %}
      - traefik.docker.network=proxy
{% endif %}
      # Router
      - traefik.http.routers.{{ item.name }}.service={{ item.name }}
      - traefik.http.routers.{{ item.name }}.rule=Host(`{{ item.traefik.subdomain }}.{{ cloudflare_dns_zone }}`)
      - traefik.http.routers.{{ item.name }}.entrypoints=secureweb
      - traefik.http.routers.{{ item.name }}.middlewares={{ item.traefik.middlewares | default(traefik_router_middlewares) }}
      # Service
      - traefik.http.services.{{ item.name }}.loadbalancer.server.scheme={{ item.traefik.scheme | default('http') }}
      - traefik.http.services.{{ item.name }}.loadbalancer.server.port={{ item.traefik.port | default(item.internal_port) }}
{% endif %}

networks:
  {{ container_network }}:
    external: true
{% if item.traefik is defined and (item.proxy_network | default(true)) and (traefik_enabled | default(false)) %}
  proxy:
    external: true
{% endif %}
